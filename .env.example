# Required
JWT_SECRET=change-me-to-a-long-random-string
TMDB_API_KEY=your-tmdb-v4-read-access-token

# Streaming Sources (at least one required for video playback)
# Real-Debrid (recommended — fastest, most reliable)
RD_API_KEY=your-real-debrid-api-token
# TorBox (fallback — works with cached torrents)
TORBOX_API_KEY=your-torbox-api-token

# Optional
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=*
